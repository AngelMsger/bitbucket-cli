# bitbucket-cli environment configuration
# Copy to .env and fill in. All variables are optional and overridable by CLI flags.

# Bitbucket site root URL
#   Cloud:       https://api.bitbucket.org  (or https://bitbucket.org)
#   Data Center: https://bitbucket.example.com
BITBUCKET_SERVER=https://api.bitbucket.org

# Backend flavor: cloud | datacenter | auto (default: auto)
BITBUCKET_FLAVOR=auto

# --- Authentication: pick ONE scheme ---

# Bearer token. Works for both flavors:
#   Cloud: Workspace / Repository / Project Access Token
#   Data Center: HTTP Access Token
BITBUCKET_TOKEN=
# (Legacy alias, also accepted)
BITBUCKET_PERSONAL_ACCESS_TOKEN=

# Basic auth:
#   Cloud: BITBUCKET_USERNAME = your email, BITBUCKET_API_TOKEN = API Token
#          (App Password is deprecated but still works in BITBUCKET_PASSWORD)
#   Data Center: BITBUCKET_USERNAME + BITBUCKET_PASSWORD
BITBUCKET_USERNAME=
BITBUCKET_PASSWORD=
BITBUCKET_API_TOKEN=

# Default workspace (Cloud) or project key (Data Center) used when commands omit it.
BITBUCKET_DEFAULT_WORKSPACE=

# Default output format: json | table | ndjson
BITBUCKET_FORMAT=json
